{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@modules/*": [
                "./src/modules/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@store/*": [
                "./src/store/*"
            ],
            "@data/*": [
                "./src/data/*"
            ]
        },
        "allowJs": true,
        "checkJs": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": [
        "src"
    ]
}